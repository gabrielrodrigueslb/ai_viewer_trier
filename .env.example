# URL base do sistema Trier na farmácia (localhost ou IP do servidor)
# Produção: http://IP_DO_SERVIDOR:4647/sgfpod1
# Homologação: https://homologacao.triersistemas.com.br/sgfpod1
TRIER_BASE_URL=http://localhost:4647/sgfpod1

# Bearer Token fornecido pela Trier para a filial
TRIER_TOKEN=seu_token_aqui

# Chave da OpenAI para ranqueamento com IA
OPENAI_API_KEY=sua_chave_openai_aqui

# Porta do servidor
PORT=5232
